{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yi-fan",
  "version": "0.0.4",
  "identifier": "com.junsen.yi-fan",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "易翻",
        "width": 800,
        "height": 600,
        "minWidth": 480,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "copyright": "MIT",
    "shortDescription": "易翻 - 轻量翻译工具",
    "longDescription": "基于 Tauri 2 + Vue 3 的跨平台轻量翻译工具，集成 21 种翻译引擎",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libxdo-dev",
          "libxcb1",
          "libxrandr2"
        ]
      },
      "rpm": {
        "depends": [
          "libxdo",
          "libxcb",
          "libXrandr"
        ]
      }
    }
  }
}
